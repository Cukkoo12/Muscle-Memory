{
    "schemaVersion": 1,
    "id": "muscle-memory",
    "version": "${version}",
    "name": "Muscle Memory",
    "description": "Skills and permanent bonuses for Minecraft.",
    "authors": ["Musa"],
    "contact": {
        "sources": "https://github.com/musa/muscle-memory"
    },
    "license": "MIT",
    "icon": "assets/muscle-memory/icon.png",
